    "print(f'  Weighted Recall   : {rec_lstm:.4f}')\n",
    "print()\n",
    "print('Per-class report:')\n",
    "print(classification_report(y_val, y_pred_lstm, target_names=label_mapping.keys(), zero_division=0))"
