  {
   "cell_type": "markdown",
   "metadata": {
    "id": "OIm607qj2IAQ"
   },
   "source": [
    "# SECTION 3: MODEL TRANSFORMATIONS\n",
    "## Step 5: Model 1 - Logistic Regression"
   ],
   "id": "OIm607qj2IAQ"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "B4jUSksb2IAR",
    "outputId": "9f563f23-278a-4500-a220-4bd0abd30c2b"
   },
   "outputs": [],
   "source": [
    "tfidf = TfidfVectorizer(\n",
    "    ngram_range=(1, 3),\n",
    "    max_features=50_000,\n",
    "    min_df=5,\n",
    "    max_df=0.90,\n",
    "    sublinear_tf=True,\n",
    "    strip_accents='unicode',\n",
    "    analyzer='word',\n",
    "    token_pattern=r'\\b[a-zA-Z][a-zA-Z]+\\b',\n",
    ")\n",
    "\n",
    "print('Vectorizing training data...')\n",
    "X_train_tfidf = tfidf.fit_transform(X_train)\n",
    "X_val_tfidf   = tfidf.transform(X_val)\n",
    "\n",
    "print(f'TF-IDF completed. Vocabulary size: {len(tfidf.vocabulary_)}')\n",
    "print(f'Train shape: {X_train_tfidf.shape}')\n",
    "print(f'Val shape:   {X_val_tfidf.shape}')\n",
    "\n",
    "lr_model = LogisticRegression(\n",
    "    multi_class='multinomial',\n",
    "    solver='saga',\n",
    "    penalty='l2',\n",
    "    max_iter=1000,\n",
    "    class_weight='balanced',\n",
    "    random_state=SEED,\n",
    ")\n",
    "\n",
    "print(\"\\nLogistic Regression model initialized.\")"
   ],
   "id": "B4jUSksb2IAR"
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "ig-NdTL82IAU"
   },
   "source": [
    "# SECTION 4: TRAINING\n",
    "### Step 5.1: Tuning the Logistic Regression\n"
,
    "I'll use a tool called 'GridSearchCV' to automatically find the best settings for our model using the validation set."
   ],
   "id": "ig-NdTL82IAU"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "oqvCPDQQ2IAV",
    "outputId": "4781da26-ac04-4bc0-c81f-f126b5b4a051"
   },
   "outputs": [],
   "source": [
    "%%time\n",
    "\n",
    "param_grid = {\n",
    "    'C': [0.1, 1.0, 5.0, 10.0],\n",
    "}\n",
    "\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=SEED)\n",
    "\n",
    "grid_search = GridSearchCV(\n",
    "    lr_model,\n",
    "    param_grid,\n",
    "    cv=cv,\n",
    "    scoring='f1_weighted',\n",
    "    n_jobs=-1,\n",
    "    verbose=1,\n",
    "    refit=True\n",
    ")\n",
    "\n",
    "grid_search.fit(X_train_tfidf, y_train)\n",
    "\n",
    "print('\\nBest Parameters:')\n",
    "for k, v in grid_search.best_params_.items():\n",
    "    print(f'  {k}: {v}')\n",
    "print(f'\\nBest CV F1 (weighted): {grid_search.best_score_:.4f}')"
   ],
   "id": "oqvCPDQQ2IAV"
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "TDaXW_Rd2IAX"
   },
   "source": [
    "### 6.2 Evaluate Logistic Regression on Validation Set"
   ],
   "id": "TDaXW_Rd2IAX"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "7P1IHXX32IAY",
    "outputId": "512f2782-0e9f-4b2b-eb55-793f6e988d62"
   },
   "outputs": [],
   "source": [
    "best_lr = grid_search.best_estimator_\n",
    "y_pred_lr = best_lr.predict(X_val_tfidf)\n",
    "\n",
    "acc_lr  = accuracy_score(y_val, y_pred_lr)\n",
    "f1_lr   = f1_score(y_val, y_pred_lr, average='weighted')\n",
    "prec_lr = precision_score(y_val, y_pred_lr, average='weighted', zero_division=0)\n",
    "rec_lr  = recall_score(y_val, y_pred_lr, average='weighted', zero_division=0)\n",
    "\n",
    "\n",
    "print('  LOGISTIC REGRESSION \u2014 VALIDATION RESULTS')\n",
    "print('=' * 55)\n",
    "print(f'  Accuracy          : {acc_lr:.4f}  ({acc_lr*100:.2f}%)')\n",
    "print(f'  Weighted F1       : {f1_lr:.4f}')\n",
    "print(f'  Weighted Precision: {prec_lr:.4f}')\n",
    "print(f'  Weighted Recall   : {rec_lr:.4f}')\n",
    "print()\n",
    "print('Per-class report:')\n",
    "print(classification_report(y_val, y_pred_lr, target_names=label_mapping.keys(), zero_division=0))"
   ],
   "id": "7P1IHXX32IAY"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 144
    },
    "id": "BZ4TLyeu2IAZ",
    "outputId": "67cd8060-e30c-4faf-c3b1-6c3986e7e498"
   },
   "outputs": [],
   "source": [
    "cm_lr = confusion_matrix(y_val, y_pred_lr)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "sns.heatmap(cm_lr, annot=True, fmt='d', cmap='Blues',\n",
