   "source": [
    "def plot_training_history(history, model_name='LSTM'):\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(14, 4))\n",
    "    epochs = range(1, len(history.history['loss']) + 1)\n",
    "\n",
    "    # Loss\n",
    "    axes[0].plot(epochs, history.history['loss'],     label='Train Loss',      color='#3498db', linewidth=2)\n",
    "    axes[0].plot(epochs, history.history['val_loss'], label='Validation Loss', color='#e74c3c', linewidth=2)\n",
    "    axes[0].set_title(f'{model_name} \u2014 Loss', fontsize=12, fontweight='bold')\n",
    "    axes[0].set_xlabel('Epoch')\n",
    "    axes[0].set_ylabel('Loss')\n",
    "    axes[0].legend()\n",
    "    axes[0].spines[['top', 'right']].set_visible(False)\n",
    "\n",
    "    # Accuracy\n",
    "    axes[1].plot(epochs, history.history['accuracy'],     label='Train Accuracy',      color='#3498db', linewidth=2)\n",
    "    axes[1].plot(epochs, history.history['val_accuracy'], label='Validation Accuracy', color='#e74c3c', linewidth=2)\n",
    "    axes[1].set_title(f'{model_name} \u2014 Accuracy', fontsize=12, fontweight='bold')\n",
    "    axes[1].set_xlabel('Epoch')\n",
    "    axes[1].set_ylabel('Accuracy')\n",
    "    axes[1].legend()\n",
    "    axes[1].spines[['top', 'right']].set_visible(False)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(f'{model_name.lower()}_training_curves.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "\n",
    "plot_training_history(history, 'LSTM-GloVe')"
   ],
   "id": "WzUESWsV2IAq"
  },
