   "source": [
    "## Step 3: Surgical Cleaning the text"
   ],
   "id": "etmxQYe-2IAH"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "X0SCkEW82IAH",
    "outputId": "cc65ce4f-c24e-46c0-f4eb-ae380327b30d"
   },
   "outputs": [],
   "source": [
    "CONTRACTIONS = {\n",
    "    \"won't\": \"will not\", \"can't\": \"can not\", \"i'm\": \"i am\",\n",
    "    \"i've\": \"i have\", \"i'll\": \"i will\", \"it's\": \"it is\",\n",
    "    \"isn't\": \"is not\", \"aren't\": \"are not\", \"wasn't\": \"was not\",\n",
    "    \"weren't\": \"were not\", \"hadn't\": \"had not\", \"hasn't\": \"has not\",\n",
    "    \"haven't\": \"have not\", \"didn't\": \"did not\", \"doesn't\": \"does not\",\n",
    "    \"wouldn't\": \"would not\", \"couldn't\": \"could not\", \"shouldn't\": \"should not\",\n",
    "    \"mustn't\": \"must not\", \"let's\": \"let us\", \"that's\": \"that is\",\n",
    "    \"who's\": \"who is\", \"what's\": \"what is\", \"there's\": \"there is\",\n",
    "    \"they're\": \"they are\", \"we're\": \"we are\", \"you're\": \"you are\",\n",
    "    \"he's\": \"he is\", \"she's\": \"she is\", \"they've\": \"they have\",\n",
    "    \"we've\": \"we have\", \"you've\": \"you have\", \"they'll\": \"they will\",\n",
    "    \"we'll\": \"we will\", \"you'll\": \"you will\",\n",
    "}\n",
    "\n",
    "SLANG_MAP = {\n",
    "    r'\\bu\\b': 'you', r'\\bpls\\b': 'please', r'\\bplz\\b': 'please',\n",
    "    r'\\btmrw\\b': 'tomorrow', r'\\bwat\\b': 'what', r'\\bwud\\b': 'would',\n",
    "    r'\\bcuz\\b': 'because', r'\\bcoz\\b': 'because', r'\\bgr8\\b': 'great',\n",
    "    r'\\bbtw\\b': 'by the way', r'\\bidk\\b': 'i do not know',\n",
    "    r'\\bomg\\b': 'oh my god', r'\\blol\\b': 'laughing', r'\\bthx\\b': 'thanks',\n",
    "    r'\\bsry\\b': 'sorry', r'\\bwanna\\b': 'want to', r'\\bgonna\\b': 'going to',\n",
    "    r'\\bgotta\\b': 'got to', r'\\bkinda\\b': 'kind of', r'\\bdunno\\b': 'do not know',\n",
    "    r'\\bfr\\b': 'for real', r'\\bnp\\b': 'no problem', r'\\bok\\b': 'okay',\n",
    "}\n",
    "\n",
    "SERVICE_PREFIX_RE = re.compile(\n",
    "    r'^(MTN|Airtel|GitHub|Slack|Gmail|WhatsApp|Forwarded message|'\n",
    "    r'From:|To:|Subject:|Date:|Sent:|On behalf of|Please consider the environment'\n",
    "    r'|This email was sent|Unsubscribe|View in browser)[:\\s].*',\n",
    "    re.IGNORECASE | re.MULTILINE\n",
    ")\n",
    "\n",
    "# Improved slang mapping including WhatsApp shortcuts\n",
    "slang_dictionary = {\n",
    "    r'\\bu\\b': 'you', r'\\bpls\\b': 'please', r'\\bplz\\b': 'please',\n",
    "    r'\\btmrw\\b': 'tomorrow', r'\\bwat\\b': 'what', r'\\bwud\\b': 'would',\n",
    "    r'\\bcuz\\b': 'because', r'\\bbtw\\b': 'by the way', r'\\bidk\\b': 'i do not know',\n",
    "    r'\\bomg\\b': 'oh my god', r'\\blol\\b': 'laughing', r'\\bthx\\b': 'thanks',\n",
    "    r'\\bsry\\b': 'sorry', r'\\bwanna\\b': 'want to', r'\\bgonna\\b': 'going to',\n",
    "    r'\\bur\\b': 'your', r'\\br\\b': 'are', r'\\bn\\b': 'and', r'\\bok\\b': 'okay'\n",
    "}\n",
    "\n",
    "def surgical_cleaner(text):\n",
    "    if type(text) != str: return \"\"\n",
    "    \n",
    "    # 1. Basic normalization\n",
    "    text = text.lower()\n",
    "    \n",
    "    # 2. Remove Technical Noise (Critical for Gmail/WhatsApp)\n",
    "    text = re.sub(r'http\\S+|www\\.\\S+|@\\w+', '', text)\n",
    "    text = re.sub(r'<.*?>', '', text) # HTML tags\n",
    "    text = re.sub(r'(mtn|github|vercel|vultr|coursera|paystack|reminder|alert):', '', text)\n",
    "    text = re.sub(r'sent from my (iphone|android|mobile)', '', text)\n",
    "    text = re.sub(r'please consider the environment before printing', '', text)\n",
    "    text = re.sub(r'--- forwarded message ---', '', text)\n",
    "    \n",
    "    # 3. Handle contractions\n",
    "    text = re.sub(r\"can't\", \"cannot\", text)\n",
    "    text = re.sub(r\"don't\", \"do not\", text)\n",
    "    text = re.sub(r\"isn't\", \"is not\", text)\n",
    "    \n",
    "    # 4. Replace slang\n",
    "    for slang, correct in slang_dictionary.items():\n",
    "        text = re.sub(slang, correct, text)\n",
    "        \n",
    "    # 5. Remove punctuation and extra spaces\n",
    "    text = text.translate(str.maketrans('', '', string.punctuation))\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    \n",
    "    return text if text else \"notification\"\n",
    "\n",
    "# Applying the surgical cleaner\n",
    "train_df['clean_text'] = train_df['text'].apply(surgical_cleaner)\n",
    "val_df['clean_text'] = val_df['text'].apply(surgical_cleaner)\n",
    "test_df['clean_text'] = test_df['text'].apply(surgical_cleaner)\n",
    "\n",
    "print(\"Surgical cleaning is done!\")"
   ],
   "id": "X0SCkEW82IAH"
  },
