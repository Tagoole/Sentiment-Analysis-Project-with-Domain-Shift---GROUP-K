  {
   "cell_type": "markdown",
   "metadata": {
    "id": "vx3ek87E2IAb"
   },
   "source": [
    "## Step 6: Preparing for deep learning\n",
    "I'll download GloVe embeddings, which are like a 'digital dictionary' that helps the LSTM model understand the meaning of words."
   ],
   "id": "vx3ek87E2IAb"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "Ixq0E2vQ2IAc",
    "outputId": "27e8c11b-2c88-4924-d164-fb634c11a212"
   },
   "outputs": [],
   "source": [
    "# Download and unzip GloVe 6B (100d)\n",
    "!wget -q --show-progress http://nlp.stanford.edu/data/glove.6B.zip\n",
    "!unzip -q glove.6B.zip\n",
    "print('GloVe downloaded and extracted.')"
   ],
   "id": "Ixq0E2vQ2IAc"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "qJIDeAeU2IAc",
    "outputId": "cca1923a-6499-4e43-83bd-4965fcc82312"
   },
   "outputs": [],
   "source": [
    "# Tokenisation parameters\n",
    "VOCAB_SIZE = 30_000\n",
    "MAX_LEN    = 120\n",
    "OOV_TOKEN  = '<OOV>'\n",
    "EMBED_DIM  = 100\n",
    "\n",
    "tokenizer = Tokenizer(\n",
    "    num_words=VOCAB_SIZE,\n",
    "    oov_token=OOV_TOKEN,\n",
    "    lower=True,\n",
    "    filters='!\"#$%&()*+,-./:;<=>?@[\\\\]^_`{|}~\\t\\n'\n",
    ")\n",
    "tokenizer.fit_on_texts(X_train)\n",
    "\n",
    "X_train_seq = tokenizer.texts_to_sequences(X_train)\n",
    "X_val_seq   = tokenizer.texts_to_sequences(X_val)\n",
    "\n",
    "X_train_pad = pad_sequences(X_train_seq, maxlen=MAX_LEN, padding='post', truncating='post')\n",
    "X_val_pad   = pad_sequences(X_val_seq,   maxlen=MAX_LEN, padding='post', truncating='post')\n",
    "\n",
    "print(f'Vocabulary size (incl. OOV): {len(tokenizer.word_index):,}')\n",
    "print(f'X_train_pad shape : {X_train_pad.shape}')\n",
    "print(f'X_val_pad   shape : {X_val_pad.shape}')"
   ],
   "id": "qJIDeAeU2IAc"
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "HZDJFiAb2IAg"
   },
   "source": [
    "## Step 7: Model 2 - LSTM"
   ],
   "id": "HZDJFiAb2IAg"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "wdj216M22IAd",
    "outputId": "cd659ce3-c3e1-4d97-d9f0-7e02b6724765"
   },
   "outputs": [],
   "source": [
    "# Load GloVe vectors\n",
    "embeddings_index = {}\n",
    "\n",
    "with open('glove.6B.100d.txt', encoding='utf8') as f:\n",
    "    for line in f:\n",
    "        values = line.split()\n",
    "        word   = values[0]\n",
    "        coefs  = np.asarray(values[1:], dtype='float32')\n",
    "        embeddings_index[word] = coefs\n",
    "\n",
    "print(f'Loaded {len(embeddings_index):,} GloVe word vectors.')"
   ],
   "id": "wdj216M22IAd"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "HMXN__Yo2IAe",
    "outputId": "bee9ef41-3bc9-451f-8fa5-ac02b61f39ab"
   },
   "outputs": [],
   "source": [
    "# Build embedding matrix\n",
    "word_index = tokenizer.word_index\n",
    "num_words  = min(VOCAB_SIZE, len(word_index) + 1)\n",
    "\n",
    "embedding_matrix = np.zeros((num_words, EMBED_DIM))\n",
    "\n",
    "covered, missing = 0, []\n",
    "for word, i in word_index.items():\n",
    "    if i >= VOCAB_SIZE:\n",
    "        continue\n",
    "    vec = embeddings_index.get(word)\n",
    "    if vec is not None:\n",
    "        embedding_matrix[i] = vec\n",
    "        covered += 1\n",
    "    else:\n",
    "        missing.append(word)\n",
    "\n",
    "coverage = covered / num_words * 100\n",
    "print(f'Embedding matrix shape : {embedding_matrix.shape}')\n",
    "print(f'Words covered by GloVe : {covered:,} / {num_words:,}  ({coverage:.1f}%)')\n",
    "print(f'OOV words (sample)     : {missing[:10]}')"
   ],
   "id": "HMXN__Yo2IAe"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "MkjJN3s32IAh",
    "outputId": "db58b377-bdd0-4156-e92d-5e993f405391"
   },
   "outputs": [],
   "source": [
    "y_train_cat = to_categorical(y_train, num_classes=NUM_CLASSES)\n",
    "y_val_cat   = to_categorical(y_val,   num_classes=NUM_CLASSES)\n",
    "\n",
    "print('y_train_cat shape:', y_train_cat.shape)\n",
    "print('y_val_cat   shape:', y_val_cat.shape)"
   ],
   "id": "MkjJN3s32IAh"
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "ritah_tuning_md"
   },
   "source": [
    "### 9.1 Hyperparameter Tuning for LSTM\n",
    "To optimize the LSTM model, we will test two different learning rates using the validation set to see which one performs better."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "ritah_tuning_code"
   },
   "outputs": [],
   "source": [
    "best_lr_lstm = 3e-4\n",
    "best_val_acc_lstm = 0\n",
    "\n",
    "for lr_val in [1e-3, 3e-4]:\n",
    "    print(f\"\\n--- Testing LSTM with Learning Rate: {lr_val} ---\")\n",
    "    temp_lstm = build_lstm_glove(num_words, EMBED_DIM, embedding_matrix, MAX_LEN, NUM_CLASSES, lr=lr_val)\n",
    "    \n",
    "    # We do a quick test for 2 epochs to see which LR is more promising\n",
    "    temp_hist = temp_lstm.fit(X_train_pad, y_train_cat, validation_data=(X_val_pad, y_val_cat), \n",
    "                              epochs=2, batch_size=64, verbose=1)\n",
    "    \n",
    "    val_acc = max(temp_hist.history['val_accuracy'])\n",
    "    if val_acc > best_val_acc_lstm:\n",
    "        best_val_acc_lstm = val_acc\n",
    "        best_lr_lstm = lr_val\n",
    "\n",
    "print(f\"\\nSuccess! The best LSTM Learning Rate is {best_lr_lstm} with Validation Accuracy of {best_val_acc_lstm:.4f}\")"
   ]
  },
